EVENHUB_HOST=127.0.0.1
EVENHUB_PORT=18791
EVENHUB_PUBLIC_ORIGIN=https://nanoclaw.example.ts.net
EVENHUB_MAX_AUDIO_BYTES=960000
EVENHUB_PAIRING_TTL_MS=300000
EVENHUB_TURN_RETENTION_MS=604800000
