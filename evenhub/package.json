{
  "name": "nanoclaw-evenhub",
  "private": true,
  "version": "0.2.1",
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "test": "vitest run",
    "pack": "evenhub pack app.json dist",
    "pack:private": "npm run build && evenhub pack -o nanoclaw-evenhub-0.2.1.ehpk app.json dist",
    "pack:verify": "npm run build && node scripts/verify-reproducible-pack.mjs",
    "simulate": "evenhub-simulator http://localhost:5173"
  },
  "dependencies": {
    "@evenrealities/even_hub_sdk": "0.0.12",
    "@evenrealities/pretext": "0.1.4"
  },
  "devDependencies": {
    "@evenrealities/evenhub-cli": "0.1.13",
    "@evenrealities/evenhub-simulator": "0.8.0",
    "typescript": "5.7.3",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  }
}
